---
import { siteConfig } from "../config";
---

<section id="liderazgo" class="bg-[var(--color-primary-dark)] text-white py-20 lg:py-28 relative overflow-hidden">
  <!-- Subtle pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='20' cy='20' r='1.5' fill='white'/%3E%3C/svg%3E\"); background-size: 40px 40px;"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 reveal">
      <p class="text-[var(--color-accent)] font-semibold text-sm uppercase tracking-widest mb-3">Reconocimiento profesional</p>
      <h2 class="text-3xl md:text-4xl font-bold" style="font-family: 'DM Serif Display', serif;">
        Liderazgo y Reconocimientos
      </h2>
      <div class="w-16 h-1 bg-[var(--color-accent)] mx-auto mt-4 rounded-full"></div>
    </div>

    <!-- Leadership cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-16">
      {siteConfig.leadership.map((item, i) => (
        <div class={`reveal stagger-${i + 1} bg-white/5 backdrop-blur-sm rounded-xl p-8 border border-white/10 text-center`}>
          <!-- Number -->
          <div class="text-5xl font-bold text-[var(--color-accent)]/30 mb-4" style="font-family: 'DM Serif Display', serif;">
            {String(i + 1).padStart(2, '0')}
          </div>
          <h3 class="text-lg font-bold text-white mb-2" style="font-family: 'DM Serif Display', serif;">
            {item.role}
          </h3>
          <p class="text-[var(--color-accent)] font-semibold text-sm mb-3">
            {item.organization}
          </p>
          <p class="text-white/50 text-sm">
            {item.scope}
          </p>
        </div>
      ))}
    </div>

    <!-- Services offered -->
    <div class="reveal">
      <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 md:p-12 border border-white/10">
        <h3 class="text-2xl font-bold text-center mb-8" style="font-family: 'DM Serif Display', serif;">
          Servicios Profesionales
        </h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {siteConfig.services.map((service, i) => (
            <div class={`flex items-start gap-3 stagger-${(i % 6) + 1}`}>
              <svg class="w-5 h-5 text-[var(--color-accent)] mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-sm text-white/70">{service}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
