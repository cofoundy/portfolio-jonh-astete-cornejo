---
import { siteConfig } from "../config";
---

<section id="trayectoria" class="bg-white py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left: About / Credentials -->
      <div class="reveal-left">
        <p class="text-[var(--color-accent)] font-semibold text-sm uppercase tracking-widest mb-3">Sobre mí</p>
        <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-primary-dark)] mb-6" style="font-family: 'DM Serif Display', serif;">
          Trayectoria Académica
        </h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          Médico con más de dos décadas dedicado a proteger la salud de los trabajadores en el Perú y América Latina. Combino la investigación científica rigurosa con la práctica clínica y la formación de nuevas generaciones de especialistas en salud ocupacional.
        </p>

        <!-- Credentials list -->
        <div class="space-y-3">
          {siteConfig.credentials.map((cred) => (
            <div class="flex items-start gap-3">
              <div class="w-2 h-2 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></div>
              <span class="text-sm text-[var(--color-primary-dark)] font-medium">{cred}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Positions -->
      <div class="space-y-6 reveal-right">
        {siteConfig.positions.map((pos, i) => (
          <div class={`relative pl-8 border-l-2 border-[var(--color-primary)]/15 pb-6 last:pb-0 stagger-${i + 1}`}>
            <!-- Dot on timeline -->
            <div class="absolute -left-[9px] top-1 w-4 h-4 rounded-full bg-[var(--color-accent)] border-4 border-white shadow-sm"></div>

            <div class="bg-[var(--color-surface)] rounded-xl p-6 border border-[var(--color-primary)]/5">
              {pos.current && (
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-green-100 text-green-700 mb-2">
                  Actual
                </span>
              )}
              <h3 class="text-lg font-bold text-[var(--color-primary-dark)]" style="font-family: 'DM Serif Display', serif;">
                {pos.role}
              </h3>
              <p class="text-[var(--color-accent)] font-semibold text-sm mt-1">
                {pos.institution}
              </p>
              <p class="text-gray-500 text-sm mt-2">
                {pos.area}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
