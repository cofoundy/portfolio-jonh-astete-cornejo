---
import { siteConfig } from "../config";
---

<footer id="contacto" class="bg-[var(--color-primary-dark)] text-white border-t border-white/10">
  <!-- Contact CTA -->
  <div class="max-w-7xl mx-auto px-6 py-16 lg:py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <!-- Left: CTA -->
      <div class="reveal-left">
        <h2 class="text-3xl md:text-4xl font-bold mb-4" style="font-family: 'DM Serif Display', serif;">
          Trabajemos juntos
        </h2>
        <p class="text-white/60 leading-relaxed mb-8 max-w-md">
          ¿Necesitas un especialista en salud ocupacional, un perito médico, o un conferencista para tu organización? Conversemos.
        </p>

        <div class="space-y-4">
          <a href={`mailto:${siteConfig.social.email}`} class="flex items-center gap-3 text-white/70 hover:text-[var(--color-accent)] transition-colors group">
            <div class="w-10 h-10 rounded-lg bg-white/5 group-hover:bg-[var(--color-accent)]/10 flex items-center justify-center transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
              </svg>
            </div>
            <span class="text-sm">{siteConfig.social.email}</span>
          </a>

          <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-white/70 hover:text-[var(--color-accent)] transition-colors group">
            <div class="w-10 h-10 rounded-lg bg-white/5 group-hover:bg-[var(--color-accent)]/10 flex items-center justify-center transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <span class="text-sm">LinkedIn</span>
          </a>

          <a href={siteConfig.social.orcid} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-white/70 hover:text-[var(--color-accent)] transition-colors group">
            <div class="w-10 h-10 rounded-lg bg-white/5 group-hover:bg-[var(--color-accent)]/10 flex items-center justify-center transition-colors">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-1.547-.856-3.722-3.853-3.722h-2.466z"/>
              </svg>
            </div>
            <span class="text-sm">ORCID: 0000-0001-6225-6720</span>
          </a>

          <a href={siteConfig.social.scholar} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-white/70 hover:text-[var(--color-accent)] transition-colors group">
            <div class="w-10 h-10 rounded-lg bg-white/5 group-hover:bg-[var(--color-accent)]/10 flex items-center justify-center transition-colors">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 24a7 7 0 110-14 7 7 0 010 14zm0-24L0 9.5l4.838 3.94A8 8 0 0112 9a8 8 0 017.162 4.44L24 9.5z"/>
              </svg>
            </div>
            <span class="text-sm">Google Scholar (853+ citaciones)</span>
          </a>
        </div>
      </div>

      <!-- Right: Affiliations -->
      <div class="reveal-right">
        <h3 class="text-lg font-bold mb-6" style="font-family: 'DM Serif Display', serif;">
          Afiliaciones Institucionales
        </h3>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white/5 rounded-lg p-4 text-center">
            <p class="text-white/80 text-sm font-semibold">UPCH</p>
            <p class="text-white/40 text-xs mt-1">Universidad Peruana Cayetano Heredia</p>
          </div>
          <div class="bg-white/5 rounded-lg p-4 text-center">
            <p class="text-white/80 text-sm font-semibold">INS / CENSOPAS</p>
            <p class="text-white/40 text-xs mt-1">Instituto Nacional de Salud</p>
          </div>
          <div class="bg-white/5 rounded-lg p-4 text-center">
            <p class="text-white/80 text-sm font-semibold">U. Continental</p>
            <p class="text-white/40 text-xs mt-1">Escuela de Posgrado</p>
          </div>
          <div class="bg-white/5 rounded-lg p-4 text-center">
            <p class="text-white/80 text-sm font-semibold">ALATSO</p>
            <p class="text-white/40 text-xs mt-1">Ex-Presidente</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10 py-6">
    <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-xs">
        &copy; {new Date().getFullYear()} Dr. Jonh M. Astete Cornejo. Todos los derechos reservados.
      </p>
      <p class="text-white/20 text-xs">
        Desarrollado por <a href="https://cofoundy.dev" target="_blank" rel="noopener noreferrer" class="text-white/30 hover:text-white/50 transition-colors">Cofoundy</a>
      </p>
    </div>
  </div>
</footer>
